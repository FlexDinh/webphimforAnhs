# Required in Vercel Production and Preview to protect /ceo.
CEO_AUTH_USERNAME=admin
CEO_AUTH_PASSWORD=change-this-before-deploy

# Keep false in production unless you intentionally want a public link to /ceo.
NEXT_PUBLIC_SHOW_CEO_LINK=false

# Public movie API configuration.
NEXT_PUBLIC_OPHIM_BASE_URL=https://ophim1.com
NEXT_PUBLIC_OPHIM_IMAGE_CDN=https://img.ophim.live
NEXT_PUBLIC_KKPHIM_BASE_URL=https://phimapi.com
NEXT_PUBLIC_NGUONC_BASE_URL=https://phim.nguonc.com/api
